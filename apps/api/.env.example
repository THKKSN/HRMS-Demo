# HRMS API — Environment Variables
# Copy to .env and fill in real values (never commit .env)
# For local dev: use `dotnet user-secrets set` instead of this file

# Database
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=hrms_db;User=hrms_user;Password=CHANGE_ME;CharSet=utf8mb4;
ConnectionStrings__Redis=localhost:6379

# JWT
Jwt__Secret=CHANGE_ME_USE_STRONG_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=hrms-api
Jwt__Audience=hrms-client
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# LINE
Line__ChannelId=CHANGE_ME
Line__ChannelSecret=CHANGE_ME
Line__LiffId=CHANGE_ME
Line__MessagingChannelAccessToken=CHANGE_ME

# CORS
AllowedOrigins__0=https://liff.line.me
AllowedOrigins__1=https://hrms.yourdomain.com

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
